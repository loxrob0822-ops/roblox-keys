# bot/.env
# ─────────────────────────────────────────────────────────────────
# Copy this file as '.env' and fill in your values before running.
# NEVER commit this file to version control.
# ─────────────────────────────────────────────────────────────────

# Your Discord bot token from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Must match the API_MASTER_TOKEN in api/.env
API_MASTER_TOKEN=change_me_super_secret_token

# Base URL of the running Flask API (no trailing slash)
API_BASE_URL=http://127.0.0.1:5000

# Discord channel ID (int) where all actions are logged.
# Set to 0 to disable logging.
LOG_CHANNEL_ID=0

# Comma-separated role names that are allowed to use bot commands.
# Role names are case-sensitive.
ALLOWED_ROLES=Admin,Staff,Moderator
