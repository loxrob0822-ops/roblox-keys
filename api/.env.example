# api/.env
# ─────────────────────────────────────────────────────────────────
# Copy this file and fill in your real values before running the API.
# NEVER commit real tokens to version control.
# ─────────────────────────────────────────────────────────────────

# Master token used by the Discord bot to authenticate with the API.
# Generate a strong random value, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
API_MASTER_TOKEN=change_me_super_secret_token

# Optional secondary read-only token (defaults to API_MASTER_TOKEN if empty)
BOT_READ_TOKEN=

# Port the Flask app listens on (default 5000)
PORT=5000

# The raw URL to your protected script (e.g. Pastebin raw)
# This is delivered privately by the server upon successful validation.
MAIN_SCRIPT_URL=https://pastebin.com/raw/your_script_id
